# ============================================================================
# LORD AI — Environment Variables
# ----------------------------------------------------------------------------
# Copy this file to `.env` and fill in the values. NEVER commit `.env`.
# On Vercel, add these as Environment Variables (Project → Settings → Environment Variables).
#
# Client-side variables (prefixed VITE_) are inlined into the browser bundle,
# so they MUST be public keys only. NEVER put a secret behind a VITE_ prefix.
# ============================================================================

# ---- Supabase (Client) -----------------------------------------------------
# Public / publishable Supabase URL and anon key. Safe to expose to the browser.
# Found in: Supabase Dashboard → Project Settings → API.
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key
# Optional alias; VITE_SUPABASE_PUBLISHABLE_KEY takes precedence.
# VITE_SUPABASE_ANON_KEY=your-anon-key

# ---- Supabase (Server) -----------------------------------------------------
# Used by server routes / server functions and by the AI auth middleware.
# These read process.env at request time (never bundled into the client).
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key
# Optional alias; SUPABASE_PUBLISHABLE_KEY takes precedence.
# SUPABASE_ANON_KEY=your-anon-key

# ---- OpenRouter (Server only) ---------------------------------------------
# Secret API key for the AI provider. Stays server-side; never expose to the
# browser. Get one at https://openrouter.ai/keys
# Without this, the /api/chat route returns 503 AI_NOT_CONFIGURED.
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional OpenRouter HTTP headers (used for usage attribution on openrouter.ai).
# OPENROUTER_REFERER=https://lordai.app
# OPENROUTER_TITLE=LordAI

# ---- Optional / Tooling ----------------------------------------------------
# Supabase project id (used by Supabase CLI / Lovable Cloud tooling).
# SUPABASE_PROJECT_ID=your-project-ref
# VITE_SUPABASE_PROJECT_ID=your-project-ref

# Supabase service role key — bypasses RLS. Only needed if you use the
# server-side admin client (src/integrations/supabase/client.server.ts).
# Treat as a SECRET. Keep server-side only.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase access token for the Supabase CLI (linking / migrations).
# Not used by the running app — keep local only.
# SUPABASE_ACCESS_TOKEN=your-supabase-access-token

# Base URL for API calls from the native (Capacitor) app. Usually left empty
# so the app calls the same origin. Only needed for mobile builds.
# VITE_API_BASE_URL=
